{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "react",
    "react-perf",
    "import",
    "jsdoc",
    "jsx-a11y",
    "nextjs",
    "node",
    "promise",
    "vitest"
  ],
  "ignorePatterns": ["node_modules", "dist", "build", ".opencode", ".agents", "*.lockb"]
}
